---
---

<section id="kontak" class="py-20 lg:py-24 bg-[#C8171D] relative overflow-hidden">
  <!-- Decorative bg pattern -->
  <div class="absolute inset-0 opacity-5">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <pattern id="egg-pattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <text x="10" y="14" font-size="12" text-anchor="middle">🥚</text>
        </pattern>
      </defs>
      <rect width="100" height="100" fill="url(#egg-pattern)"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" style="font-family: 'DM Serif Display', serif;">
      Siap Coba yang Beda?
    </h2>
    <p class="text-white/80 text-base leading-relaxed mb-8 max-w-lg mx-auto">
      Dari peternakan kami di Purworejo langsung ke dapur Anda — telur asin batu bata merah dengan rasa yang bikin ketagihan. Retail, grosir, atau kemitraan usaha — kami siap kirim.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
      <a
        href="https://wa.me/6281904186556?text=Halo+Berkah+Raya+Farm,+saya+mau+pesan+telur+asin."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-[#F5C518] hover:bg-[#D4A800] text-[#1A0A00] font-bold px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 text-base shadow-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pesan via WhatsApp
      </a>
      <a
        href="https://shopee.co.id/berkah_raya_farm"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-[#C8171D] font-semibold px-8 py-4 rounded-xl transition-all duration-200 text-base"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M21.5 7h-3.1c-.2-2.1-1.9-3.8-4-3.8S10.6 4.9 10.4 7H7.5C6.7 7 6 7.7 6 8.5l-1 11c-.1.8.5 1.5 1.3 1.5h11.4c.8 0 1.4-.7 1.3-1.5l-1-11c0-.8-.7-1.5-1.5-1.5zM12 4.7c1.3 0 2.4 1 2.6 2.3H9.4c.2-1.3 1.3-2.3 2.6-2.3zM8 10h2v2H8v-2zm6 0h2v2h-2v-2z"/>
        </svg>
        Lihat Katalog Shopee
      </a>
    </div>

    <!-- Contact info -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center text-white/70 text-sm">
      <div class="flex items-center gap-2 justify-center">
        <span>📍</span>
        <span>Toko: Ciputat, Tangerang Selatan</span>
      </div>
      <div class="hidden sm:block text-white/30">|</div>
      <div class="flex items-center gap-2 justify-center">
        <span>🕐</span>
        <span>Senin–Sabtu, 08.00–17.00 WIB</span>
      </div>
    </div>
  </div>
</section>
