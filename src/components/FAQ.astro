---
const faqs = [
  {
    q: 'Minimal order berapa butir?',
    a: 'Untuk retail, minimal order 5 butir. Untuk grosir, minimal 50 butir. Kami fleksibel — semakin banyak pesanan, semakin hemat harganya.',
  },
  {
    q: 'Berapa lama pengiriman?',
    a: 'Pengiriman Jabodetabek 1–2 hari kerja. Pesanan sebelum jam 10 pagi biasanya kami proses di hari yang sama. Untuk luar Jabodetabek, hubungi kami untuk estimasi.',
  },
  {
    q: 'Berapa lama telur asin bisa bertahan?',
    a: 'Telur asin kami bisa bertahan 14–21 hari di suhu ruang, dan hingga 30 hari jika disimpan di kulkas. Setiap kemasan ada tanggal produksi.',
  },
  {
    q: 'Apakah harga bisa nego untuk pembelian grosir?',
    a: 'Tentu. Harga grosir kami sangat kompetitif dan bisa disesuaikan dengan volume. Hubungi kami via WhatsApp untuk penawaran khusus.',
  },
  {
    q: 'Apakah bisa datang langsung ke toko?',
    a: 'Bisa! Toko offline kami di Jl. Jombang Raya No 53, Ciputat, Tangerang Selatan buka Senin–Sabtu, jam 08.00–17.00 WIB.',
  },
  {
    q: 'Bagaimana kalau produk rusak saat pengiriman?',
    a: 'Kami packing dengan sangat hati-hati. Tapi jika ada kerusakan saat pengiriman, kirim foto bukti ke WhatsApp kami — langsung kami ganti atau refund.',
  },
];
---

<section id="faq" class="py-20 lg:py-28 bg-[#FFF8E7]">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-[#C8171D] text-sm font-semibold tracking-widest uppercase mb-3">FAQ</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-[#1A0A00] mb-3" style="font-family: 'DM Serif Display', serif;">
        Yang Sering Ditanyakan
      </h2>
      <p class="text-[#5C3D2E] text-base">
        Jawaban untuk pertanyaan yang paling sering kami terima.
      </p>
    </div>

    <!-- FAQ list -->
    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class="group bg-white border border-[#F0E6C8] rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-[#1A0A00] text-base hover:text-[#C8171D] transition-colors list-none">
            {faq.q}
            <svg class="w-5 h-5 shrink-0 text-[#9A7B6A] group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="px-6 pb-4 text-[#5C3D2E] text-sm leading-relaxed">
            {faq.a}
          </div>
        </details>
      ))}
    </div>

    <!-- Still have questions -->
    <div class="text-center mt-10">
      <p class="text-[#5C3D2E] text-sm mb-3">
        Masih ada pertanyaan?
      </p>
      <a
        href="https://wa.me/6281904186556?text=Halo+Berkah+Raya+Farm,+saya+mau+tanya."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold px-5 py-3 rounded-xl transition-colors duration-200 text-sm"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Tanya via WhatsApp
      </a>
    </div>
  </div>
</section>
