---
---

<header class="sticky top-0 z-40 bg-white border-b border-[#F0E6C8] shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <img src="/logo.svg" alt="Berkah Raya Farm" class="h-10 w-10 rounded-full object-contain" />
        <span class="font-bold text-[#1A0A00] text-lg leading-tight" style="font-family: 'DM Serif Display', serif;">Berkah Raya Farm</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-8">
        <li><a href="#produk" class="text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm transition-colors">Produk</a></li>
        <li><a href="#keunggulan" class="text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm transition-colors">Keunggulan</a></li>
        <li><a href="#cara-order" class="text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm transition-colors">Cara Order</a></li>
        <li><a href="#faq" class="text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm transition-colors">FAQ</a></li>
        <li><a href="#kontak" class="text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm transition-colors">Kontak</a></li>
      </ul>

      <!-- CTA -->
      <a
        href="https://wa.me/6281904186556?text=Halo+Berkah+Raya+Farm,+saya+mau+tanya+stok+dan+harga."
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 bg-[#C8171D] hover:bg-[#A01015] text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Tanya Stok & Harga
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-[#5C3D2E] hover:text-[#C8171D] transition-colors"
        aria-label="Buka menu"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-[#F0E6C8] pt-4">
      <ul class="flex flex-col gap-3 mb-4">
        <li><a href="#produk" class="block text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm py-1 transition-colors">Produk</a></li>
        <li><a href="#keunggulan" class="block text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm py-1 transition-colors">Keunggulan</a></li>
        <li><a href="#cara-order" class="block text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm py-1 transition-colors">Cara Order</a></li>
        <li><a href="#faq" class="block text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm py-1 transition-colors">FAQ</a></li>
        <li><a href="#kontak" class="block text-[#5C3D2E] hover:text-[#C8171D] font-medium text-sm py-1 transition-colors">Kontak</a></li>
      </ul>
      <a
        href="https://wa.me/6281904186556?text=Halo+Berkah+Raya+Farm,+saya+mau+tanya+stok+dan+harga."
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 bg-[#C8171D] hover:bg-[#A01015] text-white text-sm font-semibold px-4 py-3 rounded-lg transition-colors duration-200 w-full"
      >
        Tanya via WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on nav link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
