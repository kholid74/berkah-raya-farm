---
const testimonials = [
  {
    quote: 'Sudah 6 bulan jadi supplier tetap untuk resto kami. Pengiriman selalu tepat waktu dan kualitas telur asinnya nggak pernah turun. Pelanggan pada bilang enak.',
    name: 'Pak Hendra',
    role: 'Pemilik Rumah Makan — Jakarta',
    initials: 'PH',
    color: 'bg-[#C8171D]',
  },
  {
    quote: 'Pesan buat katering acara nikahan 500 tamu, semua puas. Telur asinnya gurih, kuningnya pulen, packing rapi. Udah jadi langganan tetap.',
    name: 'Bu Wulandari',
    role: 'Pemilik Katering — Bekasi',
    initials: 'BW',
    color: 'bg-[#5C3D2E]',
  },
  {
    quote: 'Reseller udah 4 bulan. Pelanggan saya bilang telur asinnya beda — lebih gurih dan nggak amis. Repeat order terus.',
    name: 'Bu Dewi',
    role: 'Reseller — Depok',
    initials: 'BD',
    color: 'bg-[#A01015]',
  },
];
---

<section class="py-20 lg:py-28 bg-[#FFFBF0]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-[#C8171D] text-sm font-semibold tracking-widest uppercase mb-3">Testimoni</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-[#1A0A00]" style="font-family: 'DM Serif Display', serif;">
        Dipercaya Pelanggan Retail & Bisnis
      </h2>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white border border-[#F0E6C8] rounded-2xl p-7 flex flex-col hover:shadow-md transition-shadow duration-300">
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array(5).fill(null).map(() => (
              <svg class="w-4 h-4 text-[#F5C518]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-[#5C3D2E] text-sm leading-relaxed flex-1 mb-6 italic">
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full ${t.color} text-white text-sm font-bold flex items-center justify-center shrink-0`}>
              {t.initials}
            </div>
            <div>
              <p class="text-[#1A0A00] font-semibold text-sm">{t.name}</p>
              <p class="text-[#9A7B6A] text-xs">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
