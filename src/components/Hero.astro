---
---

<section class="relative min-h-[90vh] w-full flex items-center overflow-hidden bg-[#FFFBF0]">
  <!-- Subtle warm radial glow -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#F5C518]/8 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#C8171D]/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 w-full min-w-0 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <!-- Left: Text content -->
      <div class="w-full min-w-0">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-[#F5C518]/15 border border-[#F5C518]/30 text-[#8B6914] text-sm font-semibold px-4 py-2 rounded-full mb-6">
          <span>🧱</span>
          <span>Batu Bata Merah Asli · Peternakan Sendiri</span>
        </div>

        <!-- H1 -->
        <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold text-[#1A0A00] leading-tight mb-6" style="font-family: 'DM Serif Display', serif;">
          Dari Kandang Kami di Purworejo.<br />
          <span class="text-[#C8171D]">Telur Asin Premium</span> Batu Bata Merah.
        </h1>

        <!-- Sub text -->
        <p class="text-[#5C3D2E] text-base sm:text-lg leading-relaxed mb-8 w-full max-w-lg">
          Dari kandang kami di Purworejo langsung ke dapur Anda. Diasinkan pakai batu bata merah asli — metode turun-temurun yang bikin kuning telur pulen dan gurihnya nendang.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href="https://wa.me/6281904186556?text=Halo+Berkah+Raya+Farm,+saya+mau+coba+sample+pack+telur+asin."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-[#C8171D] hover:bg-[#A01015] text-white font-semibold px-7 py-4 rounded-xl transition-all duration-200 hover:scale-105 text-base shadow-lg shadow-[#C8171D]/20"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pesan via WhatsApp
          </a>
          <a
            href="https://shopee.co.id/berkah_raya_farm"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 border-2 border-[#D4C8A8] hover:border-[#C8171D] text-[#5C3D2E] hover:text-[#C8171D] font-semibold px-7 py-4 rounded-xl transition-all duration-200 text-base"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M21.5 7h-3.1c-.2-2.1-1.9-3.8-4-3.8S10.6 4.9 10.4 7H7.5C6.7 7 6 7.7 6 8.5l-1 11c-.1.8.5 1.5 1.3 1.5h11.4c.8 0 1.4-.7 1.3-1.5l-1-11c0-.8-.7-1.5-1.5-1.5zM12 4.7c1.3 0 2.4 1 2.6 2.3H9.4c.2-1.3 1.3-2.3 2.6-2.3zM8 10h2v2H8v-2zm6 0h2v2h-2v-2z"/>
            </svg>
            Lihat Katalog Shopee
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-x-5 gap-y-2">
          {[
            { icon: '🐔', text: 'Hasil peternakan sendiri' },
            { icon: '🧱', text: 'Batu bata merah asli' },
            { icon: '📦', text: 'Panen pagi, kirim siang' },
          ].map((badge) => (
            <div class="flex items-center gap-1.5 text-[#6B5B4E] text-sm">
              <span>{badge.icon}</span>
              <span>{badge.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Hero image -->
      <div class="relative hidden lg:block">
        <!-- Main product image -->
        <div class="relative z-10">
          <img
            src="/images/products/telur-asin-hero.jpg"
            alt="Telur asin premium — kuning telur berminyak dan gurih"
            class="w-full max-w-[480px] mx-auto aspect-square object-cover rounded-3xl shadow-2xl shadow-[#1A0A00]/15"
            loading="eager"
          />
        </div>
        
        <!-- Floating card: rating -->
        <div class="absolute -bottom-5 -left-2 z-20 bg-white rounded-2xl px-5 py-4 shadow-xl shadow-[#1A0A00]/8 border border-[#F0E6C8]">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-[#F5C518]/15 rounded-xl flex items-center justify-center text-2xl">⭐</div>
            <div>
              <div class="text-[#1A0A00] font-bold text-lg leading-tight">4.9 / 5.0</div>
              <div class="text-[#9A7B6A] text-xs">Rating di Shopee</div>
            </div>
          </div>
        </div>

        <!-- Floating card: freshness -->
        <div class="absolute -top-4 -right-2 z-20 bg-white rounded-full px-5 py-3 shadow-lg shadow-[#1A0A00]/6 border border-[#F0E6C8] flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></span>
          <span class="text-[#1A0A00] font-semibold text-sm">Panen Hari Ini</span>
        </div>
      </div>

      <!-- Mobile: image below text -->
      <div class="lg:hidden mt-6">
        <img
          src="/images/products/telur-asin-hero.jpg"
          alt="Telur asin premium — kuning telur berminyak dan gurih"
          class="w-full max-w-[320px] mx-auto aspect-square object-cover rounded-2xl shadow-xl"
          loading="eager"
        />
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[#D4C8A8] hidden lg:block animate-bounce">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
